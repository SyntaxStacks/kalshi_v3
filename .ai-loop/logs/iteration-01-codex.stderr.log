pub fn parse_lane_key(lane: &str) -> Option<ParsedLaneKey> {
    let parts: Vec<&str> = lane.split(':').collect();
    if parts.len() != 6 && parts.len() != 7 {
        return None;
    }
    let expiry_regime = if parts.len() == 7 {
        match parts[6] {
