fn proportional_entry_fee(total_entry_fee: f64, exit_quantity: f64, total_quantity: f64) -> f64 {
    if total_entry_fee <= 0.0 || total_quantity <= 0.0 {
        0.0
    } else {
        (total_entry_fee * (exit_quantity / total_quantity)).max(0.0)
    }
